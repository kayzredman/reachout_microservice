# ─── Clerk Authentication ──────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ─── Database (PostgreSQL) ─────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/faithreach

# ─── OAuth: X (Twitter) ───────────────────────────────────
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# ─── OAuth: Meta (Instagram & Facebook) ───────────────────
META_APP_ID=
META_APP_SECRET=

# ─── OAuth: Google (YouTube) ──────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── AI / OpenAI ──────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Clerk Webhook ────────────────────────────────────────
CLERK_WEBHOOK_SECRET=whsec_...

# ─── Flutterwave (payments) ──────────────────────────────
FLW_PUBLIC_KEY=FLWPUBK_TEST-...
FLW_SECRET_KEY=FLWSECK_TEST-...
FLW_WEBHOOK_HASH=

# ─── Frontend ─────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── SMTP / Email ────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@faithreach.io

# ─── Service URLs (used by frontend API proxies) ──────────
USER_SERVICE_URL=http://localhost:3002
POST_SERVICE_URL=http://localhost:3003
PLATFORM_SERVICE_URL=http://localhost:3009
AI_SERVICE_URL=http://localhost:3006
CONTENT_PLANNER_URL=http://localhost:3007
BILLING_SERVICE_URL=http://localhost:3008
AI_ASSISTANT_URL=http://localhost:3006

# ─── Service Ports ────────────────────────────────────────
# Auth:                 3001  (scaffold — Clerk handles auth)
# User:                 3002
# Post:                 3003
# Notification:         3004  (scaffold)
# Analytics:            3005  (scaffold)
# AI Assistant:         3006
# Content Planner:      3007
# Billing:              3008
# Platform Integration: 3009
# Scheduler:            3010
