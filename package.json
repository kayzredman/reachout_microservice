{
  "packageManager": "pnpm@10.29.3",
  "name": "faithreach-monorepo",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "services/*",
    "frontend",
    "shared"
  ],
  "devDependencies": {
    "turbo": "latest"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:profile": "turbo run dev --filter=frontend --filter=user --parallel",
    "build": "turbo run build",
    "build:profile": "turbo run build --filter=frontend --filter=user",
    "lint": "turbo run lint",
    "docker:up": "./scripts/dev-up.sh",
    "docker:down": "docker compose down",
    "docker:rebuild": "docker compose up --build -d",
    "docker:logs": "docker compose logs -f",
    "seed": "node scripts/seed-demo.mjs"
  },
  "dependencies": {
    "@clerk/clerk-sdk-node": "^5.1.6",
    "@types/express": "^5.0.6",
    "pg": "^8.20.0"
  }
}
